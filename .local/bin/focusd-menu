#!/usr/bin/env bash
# Focusd pomodoro menu via Walker dmenu
# Super+Shift+P to launch

choice=$(printf '%s\n' \
  '’üŗ Start' \
  '’üī Pause' \
  '’üŗ Resume' \
  '’łģ Toggle' \
  '’Ć× Reset' \
  '¾░ÆŁ Next' \
  '’ÉĘ Stats' \
  '’ćÜ History' \
  '¾░¦© TUI' \
  | walker --dmenu -p "focusd:")

case "$choice" in
  '’üŗ Start') focusd start ;;
  '’üī Pause') focusd pause ;;
  '’üŗ Resume') focusd resume ;;
  '’łģ Toggle') focusd toggle ;;
  '’Ć× Reset') focusd reset ;;
  '¾░ÆŁ Next') focusd next ;;
  '’ÉĘ Stats') uwsm-app -- xdg-terminal-exec focusd stats ;;
  '’ćÜ History') uwsm-app -- xdg-terminal-exec focusd history ;;
  '¾░¦© TUI') uwsm-app -- xdg-terminal-exec focusd ;;
esac
